{
  "appId": "com.elewinreader.app",
  "productName": "EleWinReader",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "extraResources": [
    {
      "from": "node_modules/sql.js/dist/",
      "to": "sql.js",
      "filter": ["sql-wasm.wasm"]
    }
  ],
  "publish": {
    "provider": "github",
    "owner": "Metahumanz",
    "repo": "EleReaderWin"
  },
  "artifactName": "${productName}-${version}-Setup.${ext}",
  "win": {
    "target": "nsis",
    "icon": "public/icon.png"
  },
  "mac": {
    "target": "dmg",
    "icon": "public/icon.png"
  },
  "linux": {
    "target": "AppImage",
    "icon": "public/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true
  }
}
