{
  "name": "ele-win-reader",
  "version": "0.1.3",
  "description": "A modern desktop reader application built with Electron and Vue",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite && electron .",
    "electron:build": "vue-tsc && vite build && electron-builder --win",
    "electron:build:mac": "vue-tsc && vite build && electron-builder --mac",
    "electron:build:linux": "vue-tsc && vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "sql.js": "^1.11.0",
    "epubjs": "^0.3.93",
    "jschardet": "^3.1.4",
    "iconv-lite": "^0.6.3",
    "webdav": "^5.8.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^2.2.0"
  }
}
